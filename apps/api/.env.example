# Slot API 환경변수 예시
# 실제 사용 시 이 파일을 복사해 apps/api/.env 로 만들고 값을 채운다.

# 서버 포트 (기본 3001)
PORT=3001

# ── 호스트(나) 정보 — 개인정보이므로 환경변수로 관리 ──
HOST_NAME=Slot Host
HOST_EMAIL=host@example.com
HOST_TIMEZONE=Asia/Seoul

# 캘린더 구현 선택: mock(기본) | google
CALENDAR_PROVIDER=mock

# ── Google Calendar 실연동용 (CALENDAR_PROVIDER=google 일 때 필요) ──
# Google Cloud Console > API & Services > Credentials 에서 OAuth 2.0 클라이언트 생성
#  - 승인된 리디렉션 URI 에 아래 GOOGLE_REDIRECT_URI 를 등록
#  - Google Calendar API 사용 설정
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# 호스트가 1회 동의 후 발급 (http://localhost:3001/api/auth/google 접속 → 화면에 출력됨)
GOOGLE_REFRESH_TOKEN=

# 대상 캘린더 (기본 primary)
GOOGLE_CALENDAR_ID=primary

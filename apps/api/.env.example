# Slot API 환경변수 예시
# 실제 사용 시 이 파일을 복사해 apps/api/.env 로 만들고 값을 채운다.

# 서버 포트 (기본 3001)
PORT=3001

# ── 호스트(나) 정보 — 개인정보이므로 환경변수로 관리 ──
HOST_SLUG=me
HOST_NAME=Slot Host
HOST_EMAIL=host@example.com
HOST_TIMEZONE=Asia/Seoul
# 추가 호스트는 apps/api/src/config/schedule.config.ts 의 hosts 배열에 등록 (?host=<slug>)

# 캘린더 구현 선택: mock(기본) | google
CALENDAR_PROVIDER=mock

# ── Google Calendar 실연동용 (CALENDAR_PROVIDER=google 일 때 필요) ──
# Google Cloud Console > API & Services > Credentials 에서 OAuth 2.0 클라이언트 생성
#  - 승인된 리디렉션 URI 에 아래 GOOGLE_REDIRECT_URI 를 등록
#  - Google Calendar API 사용 설정
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# 호스트가 1회 동의 후 발급 (http://localhost:3001/api/auth/google 접속 → 화면에 출력됨)
GOOGLE_REFRESH_TOKEN=

# 대상 캘린더 (기본 primary)
GOOGLE_CALENDAR_ID=primary

# ── 알림 ──
# 알림 구현: mock(기본, 콘솔) | email(SMTP)
NOTIFY_PROVIDER=mock
# 이메일 알림에 들어갈 예약 관리 링크의 기본 주소
APP_BASE_URL=http://localhost:5173
# NOTIFY_PROVIDER=email 일 때 필요
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Slot <no-reply@slot.local>

# 호스트(나)에게 텔레그램 알림 — 누가/언제 예약했는지: mock(기본, 콘솔) | telegram | off
NOTIFY_TELEGRAM_PROVIDER=mock
# NOTIFY_TELEGRAM_PROVIDER=telegram 일 때 필요
#  1) 텔레그램 @BotFather 에서 봇 생성 → 토큰 복사
#  2) 만든 봇에게 아무 메시지 전송 후 https://api.telegram.org/bot<토큰>/getUpdates 에서 chat.id 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 방문자 SMS 알림: off(기본) | mock(콘솔) | twilio
NOTIFY_SMS_PROVIDER=off
# NOTIFY_SMS_PROVIDER=twilio 일 때 필요
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
# 로컬 번호(010-…)를 E.164 로 바꿀 국가코드
SMS_DEFAULT_COUNTRY_CODE=+82
